generator client {
  provider        = "prisma-client"
  output          = "./generated"
  moduleFormat    = "cjs"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id String @id @db.Char(36)

  accountId String @map("account_id") @db.Char(36)

  amount         BigInt
  currency       String @db.VarChar(10)
  type           String @db.VarChar(50)
  status         String @db.VarChar(50)
  idempotencyKey String @unique @map("idempotency_key") @db.VarChar(40)

  // депозиты
  provider          String? @db.VarChar(20)
  method            String? @db.VarChar(20)
  providerPaymentId String? @unique @map("provider_payment_id")

  // трансферы
  referenceId String? @map("reference_id") @db.Char(36)

  // выводы
  withdrawalAccount String? @map("withdrawal_account")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  outboxEvents OutboxEvent[]

  @@index([accountId])
  @@index([status])
  @@index([providerPaymentId])
  @@index([accountId, currency])
  @@map("transactions")
}

model OutboxEvent {
  id            String @id @db.Char(36)
  transactionId String @map("transaction_id") @db.Char(36)

  topic     String  @db.VarChar(100)
  payload   Json
  processed Boolean @default(false)

  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([processed, createdAt])
  @@map("outbox_events")
}
