generator client {
  provider        = "prisma-client"
  output          = "./generated"
  moduleFormat    = "cjs"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id String @id @db.Char(36)

  accountId String @map("account_id") @db.Char(36)

  amount         BigInt
  currency       String @db.VarChar(10)
  type           String @db.VarChar(50)
  status         String @db.VarChar(50)
  idempotencyKey String @unique @map("idempotency_key") @db.VarChar(36)

  provider          String?
  providerPaymentId String? @unique @map("provider_payment_id")

  counterpartyAccountId String? @map("counterparty_account_id") @db.Char(36)
  referenceId           String? @map("reference_id") @db.Char(36)

  withdrawalAccount String? @map("withdrawal_account")

  retryCount Int      @default(0) @map("retry_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  outboxEvents OutboxEvent?

  @@index([accountId])
  @@index([status])
  @@index([providerPaymentId])
  @@index([accountId, currency])
  @@map("transactions")
}

model OutboxEvent {
  id            String @id @db.Char(36)
  transactionId String @unique @map("transaction_id") @db.Char(36)

  topic      String  @db.VarChar(100)
  payload    Json
  processed  Boolean @default(false)
  retryCount Int     @default(0) @map("retry_count")

  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")
  failedAt    DateTime? @map("failed_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([processed, createdAt])
  @@map("outbox_events")
}
