# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=users

# Redis
REDIS_PASSWORD=123456

# MinIO 
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# KAFKA

# === Identification ===
KAFKA_NODE_ID=1 
CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk 
# уникальный ID этого брокера в кластере. В dev всегда 1, в проде у каждого брокера свой номер.
# уникальный ID всего кластера в base64. Генерируется один раз при создании, потом не меняется.

# === Roles ===
KAFKA_PROCESS_ROLES=broker,controller 
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093 
# в dev один процесс совмещает обе роли. В проде обычно разделяют: отдельные controller-узлы и отдельные broker-узлы.
# список controller'ов для кворума. Формат node_id@host:port. В dev один узел, в проде обычно 3 controller'а для отказоустойчивости.

# === Listeners ===
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093,PLAINTEXT_HOST://0.0.0.0:9094 
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:9094 
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
# на каких адресах/портах Kafka слушает входящие соединения. 0.0.0.0 значит на всех интерфейсах.
# что Kafka сообщает клиентам когда те подключаются. 
# маппинг имени listener'а на протокол. Все три у нас PLAINTEXT (без TLS). В проде PLAINTEXT заменяется на SSL или SASL_SSL.

# === Репликация ===
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1 
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
# Всё по 1 потому что у нас один брокер. В проде с тремя брокерами ставят 3 и 2 соответственно. Если оставить 1 в проде с кластером — потеряешь данные при падении брокера.

KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
# топики создаются автоматически при первой публикации. В проде обычно false — топики создают явно с нужными настройками (retention, partitions, replication).

# UI
KAFKA_CLUSTERS_0_NAME=local
KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS=kafka:9092